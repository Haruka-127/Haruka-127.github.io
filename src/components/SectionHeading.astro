---
interface Props { eyebrow: string; title: string; description?: string }
const { eyebrow, title, description } = Astro.props;
---
<div class="section-heading mb-10 md:mb-16">
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-3 max-w-3xl text-3xl font-bold leading-tight tracking-[-0.035em] text-slate-950 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">{description}</p>}
</div>
