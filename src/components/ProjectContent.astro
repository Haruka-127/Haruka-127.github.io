---
import type { ProjectSection } from '../data/projectDetails';

interface Props {
  sections: readonly ProjectSection[];
}

const { sections } = Astro.props;
---

<article class="mt-12 max-w-2xl border-t border-slate-200">
  {sections.map((section) => (
    <section class="border-b border-slate-200 py-12 first:pt-10">
      <h2 class="text-2xl font-semibold tracking-[-0.025em] text-black sm:text-3xl">{section.title}</h2>

      {section.paragraphs && (
        <div class="mt-6 space-y-5 text-base leading-8 text-slate-700">
          {section.paragraphs.map((paragraph) => <p class="whitespace-pre-line">{paragraph}</p>)}
        </div>
      )}

      {section.items && (
        <ul class="mt-7 grid gap-x-8 border-t border-slate-200 text-sm text-slate-700 sm:grid-cols-2">
          {section.items.map((item) => <li class="border-b border-slate-200 py-3">{item}</li>)}
        </ul>
      )}

      {section.subsections && (
        <div class="mt-9 space-y-10">
          {section.subsections.map((subsection) => (
            <section>
              <h3 class="text-lg font-semibold tracking-[-0.015em] text-black">{subsection.title}</h3>

              {subsection.paragraphs && (
                <div class="mt-4 space-y-4 text-base leading-8 text-slate-700">
                  {subsection.paragraphs.map((paragraph) => <p class="whitespace-pre-line">{paragraph}</p>)}
                </div>
              )}

              {subsection.items && (
                <ul class="mt-5 grid gap-x-8 border-t border-slate-200 text-sm text-slate-700 sm:grid-cols-2">
                  {subsection.items.map((item) => <li class="border-b border-slate-200 py-3">{item}</li>)}
                </ul>
              )}
            </section>
          ))}
        </div>
      )}
    </section>
  ))}
</article>
