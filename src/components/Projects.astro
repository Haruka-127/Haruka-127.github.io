---
import SectionHeading from './SectionHeading.astro';
import Tag from './Tag.astro';
import BudouxText from './BudouxText.astro';
import { projects } from '../data/projects';
---
<section id="projects" class="section-shell reveal">
  <SectionHeading eyebrow="04 / PROJECTS" title="Projects" />
  <ol class="border-t border-slate-200">
    {projects.map((project, index) => (
      <li class="grid gap-5 border-b border-slate-200 py-8 sm:grid-cols-[2rem_1fr_auto] sm:items-start">
        <span class="font-mono text-[.6rem] text-slate-400">{String(index + 1).padStart(2, '0')}</span>
        <div>
          <h3 class="text-2xl font-medium text-black"><BudouxText text={project.title} /></h3>
          <p class="mt-4 whitespace-pre-line text-sm leading-7 text-slate-700"><BudouxText text={project.summary} /></p>
          <a class="mt-5 inline-block text-sm text-black underline underline-offset-4 hover:no-underline" href={`/projects/${project.slug}/`}>詳細を見る <span aria-hidden="true">→</span></a>
        </div>
        <Tag text={project.status} />
      </li>
    ))}
  </ol>
</section>
