---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Tag from '../../components/Tag.astro';
import ProjectContent from '../../components/ProjectContent.astro';
import { profile } from '../../data/profile';
import { projects, type Project } from '../../data/projects';

export const getStaticPaths = (() => projects.map((project) => ({
  params: { slug: project.slug },
  props: { project },
}))) satisfies GetStaticPaths;

interface Props { project: Project }
const { project } = Astro.props;

const repository = (() => {
  if (!project.repositoryUrl) return undefined;

  const url = new URL(project.repositoryUrl);
  const [owner, name] = url.pathname.split('/').filter(Boolean);
  const isGitHubRepository = url.hostname === 'github.com' && owner && name;

  return {
    url: url.toString(),
    label: isGitHubRepository ? `${owner}/${name}` : url.hostname,
    previewImageUrl: isGitHubRepository
      ? `https://opengraph.githubassets.com/1/${owner}/${name}`
      : undefined,
  };
})();
---
<Layout title={`${project.title} | ${profile.handle}`} description={project.summary}>
  <Header />
  <main id="main-content" class="container-shell py-20 sm:py-28">
    <p class="eyebrow">PROJECT</p>
    <h1 class="mt-3 max-w-3xl text-[clamp(2.25rem,8vw,5rem)] font-bold leading-tight tracking-[-0.055em] text-black">
      {project.titleParts.map((part, index) => (
        <>{index > 0 && <wbr />}<span class="whitespace-nowrap">{part}</span></>
      ))}
    </h1>
    <div class="mt-8"><Tag text={project.status} /></div>
    <p class="mt-10 max-w-2xl whitespace-pre-line text-base leading-8 text-slate-700">{project.summary}</p>
    {project.content ? (
      <ProjectContent sections={project.content} />
    ) : (
      <div class="mt-12 border-t border-slate-200 pt-10">
        <p class="max-w-2xl whitespace-pre-line text-base leading-8 text-slate-700">{project.body}</p>
      </div>
    )}
    {repository && (
      <a
        class="mt-12 block max-w-2xl overflow-hidden border border-slate-200 text-black transition-colors hover:border-slate-500"
        href={repository.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${repository.label}のGitHubリポジトリを開く（新しいタブ）`}
      >
        {repository.previewImageUrl && (
          <img
            class="block aspect-[2/1] w-full bg-slate-100 object-cover"
            src={repository.previewImageUrl}
            alt={`${repository.label}のGitHubプレビュー`}
            width="1200"
            height="600"
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
        )}
        <span class="flex items-center justify-between gap-4 border-t border-slate-200 px-5 py-4 text-sm">
          <span class="min-w-0 break-all">{repository.label}</span>
          <span class="shrink-0" aria-hidden="true">↗</span>
        </span>
      </a>
    )}
    <a class="mt-16 inline-block text-sm text-black underline underline-offset-4 hover:no-underline" href="/#projects">← Projectsへ戻る</a>
  </main>
  <Footer />
</Layout>
